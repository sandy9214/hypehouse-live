# Rust
/engine/target/
/engine/Cargo.lock.bak
/tauri/target/
/tauri/gen/
**/*.rs.bk

# Node / Vite
/ui/node_modules/
/ui/dist/
/ui/.vite/
# Catch-all so any stray `npm install` (from the repo root, or
# inside a subdir we haven't carved out) doesn't sneak deps into
# the tree.
**/node_modules/

# Python (copilot service)
/copilot/__pycache__/
/copilot/.pytest_cache/
/copilot/.ruff_cache/
/copilot/.mypy_cache/
/copilot/venv/
/copilot/*.egg-info/

# Editors / OS
.DS_Store
.vscode/
.idea/

# Local secrets / env
.env
.env.local

# Claude worktrees + per-directory `.claude/` artifacts (settings,
# session checkpoints, agent caches). These are per-user / per-env
# state — never want them tracked.
.claude/worktrees/
.claude/
**/.claude/

# Test artifacts
*.log
