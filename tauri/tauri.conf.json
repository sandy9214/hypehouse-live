{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HypeHouse Live",
  "version": "0.1.0",
  "identifier": "live.hypehouse.desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "HypeHouse Live",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon.png"
    ],
    "category": "Music",
    "shortDescription": "Live multi-deck DJ player with AI co-pilot",
    "longDescription": "HypeHouse Live is a Rust-powered live DJ application featuring sub-5ms audio latency, native MIDI controller support, and an optional AI co-pilot for AI-driven track selection and phrase-aligned transitions.",
    "macOS": {
      "minimumSystemVersion": "10.13",
      "hardenedRuntime": true
    },
    "windows": {
      "digestAlgorithm": "sha256"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": true,
      "pubkey": "PLACEHOLDER_REPLACE_WITH_OUTPUT_OF_TAURI_SIGNER_GENERATE_PUB",
      "endpoints": [
        "https://hypehouse.live/releases/stable/manifest.json?target={{target}}&arch={{arch}}&current={{current_version}}",
        "https://github.com/sandy9214/hypehouse-live/releases/latest/download/manifest.json"
      ]
    }
  }
}
